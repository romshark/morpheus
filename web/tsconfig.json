{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"esModuleInterop": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"noEmit": true
	},
	"include": ["lib/**/*.ts", "site/**/*.ts", "build.ts"]
}

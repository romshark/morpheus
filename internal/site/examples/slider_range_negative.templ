package examples

import "github.com/romshark/morpheus/neo"

templ SliderRangeNegative() {
	@neo.SliderRange(neo.SliderRangeOpts[float64]{
		Min:      neo.Set(-50.0),
		Max:      neo.Set(50.0),
		Step:     neo.Set(1.0),
		ValueMin: neo.Set(-15.0),
		ValueMax: neo.Set(20.0),
		Label:    neo.Set("Pan"),
	})
}

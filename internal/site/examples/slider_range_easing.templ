package examples

import "github.com/romshark/morpheus/neo"

templ SliderRangeEasing() {
	@neo.SliderRange(neo.SliderRangeOpts[float64]{
		Min:      neo.Set(0.0),
		Max:      neo.Set(100.0),
		Step:     neo.Set(1.0),
		ValueMin: neo.Set(20.0),
		ValueMax: neo.Set(70.0),
		Label:    neo.Set("Brightness"),
		Unit:     neo.Set("%"),
		Easing:   neo.Set("320ms cubic-bezier(0.34, 1.35, 0.64, 1)"),
	})
}

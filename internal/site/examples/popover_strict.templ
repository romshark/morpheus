templ PopoverStrict() {
	@neo.PopoverAttrs(neo.PopoverOpts{
		Placement:    neo.Set(neo.PlacementBottomStart),
		ScreenOffset: neo.Set("1rem"),
		MinFitHeight: neo.Set("8rem"),
		Flip:         neo.Set(false),
	}, nil) {
		<neo-button { neo.PopoverTrigger()... }>Strict bottom-start</neo-button>
		<div { neo.PopoverContent()... }>
			<h3>Long list</h3>
			<ul class="popover-strict-list">
				for _, name := range popoverStrictCountries {
					<li>{ name }</li>
				}
			</ul>
		</div>
	}
}

package examples

import "github.com/romshark/morpheus/neo"

templ SliderRangeBare() {
	@neo.SliderRange(neo.SliderRangeOpts[float64]{
		Min:       neo.Set(0.0),
		Max:       neo.Set(100.0),
		Step:      neo.Set(1.0),
		ValueMin:  neo.Set(35.0),
		ValueMax:  neo.Set(80.0),
		HideValue: neo.Set(true),
	})
}
